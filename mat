#!/usr/bin/env bash
# mat — mini_agent_team 快捷指令
# 安裝後可在任何目錄執行：mat install-cmd
set -euo pipefail

# Resolve the real path of this script — works on macOS (no GNU readlink),
# any Linux distro, and through symlinks. Prefer realpath/greadlink/readlink -f
# in that order; fall back to a Python one-liner which is universally available
# on systems that have python3 (which the project requires anyway).
_resolve_self() {
    local target="$1"
    if command -v realpath >/dev/null 2>&1; then
        realpath "$target"
    elif command -v greadlink >/dev/null 2>&1; then
        greadlink -f "$target"
    elif readlink -f "$target" >/dev/null 2>&1; then
        readlink -f "$target"
    elif command -v python3 >/dev/null 2>&1; then
        python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$target"
    else
        # Last resort: relative path resolution; works only if not symlinked.
        local _d _b
        _d="$(cd "$(dirname "$target")" && pwd -P)"
        _b="$(basename "$target")"
        printf '%s/%s\n' "$_d" "$_b"
    fi
}

_SELF="$(_resolve_self "$0")"
MAT_DIR="$(cd "$(dirname "$_SELF")" && pwd -P)"
AGENT="$MAT_DIR/agent"
PYTHON="$MAT_DIR/venv/bin/python3"
STATE="$MAT_DIR/data/setup-state.json"
COMPOSE="$MAT_DIR/docker-compose.yml"

_check_venv() {
    if [ ! -x "$PYTHON" ]; then
        echo "❌  venv 尚未建立，請先執行：mat setup"
        exit 1
    fi
}

# Read deploy_mode from setup state — single source of truth for which
# backend (launchd/systemd vs docker) the user picked in the wizard.
# Fallback: docker if docker-compose.yml exists; else "agent" (launchd/systemd).
_deploy_mode() {
    if [ -f "$STATE" ] && command -v python3 >/dev/null 2>&1; then
        python3 - "$STATE" <<'PY' 2>/dev/null || true
import json, sys
try:
    print((json.load(open(sys.argv[1])).get("deploy_mode") or "").strip())
except Exception:
    pass
PY
    fi
}

# Resolve the dispatcher: "docker" | "agent" (covers foreground / launchd / systemd).
_backend() {
    local mode
    mode="$(_deploy_mode)"
    case "$mode" in
        docker)             echo "docker" ;;
        systemd|launchd)    echo "agent"  ;;
        foreground)         echo "agent"  ;;  # `agent` script gracefully handles foreground/launchd on macOS
        *)
            # Fall back to filesystem hint if state file is missing/garbled.
            if [ -f "$COMPOSE" ]; then
                echo "docker"
            else
                echo "agent"
            fi
            ;;
    esac
}

# `docker compose` is `docker compose` on modern Docker; the legacy
# `docker-compose` binary is not used here. Keep the lookup explicit so
# error messages stay clear when Docker isn't installed.
_dc() {
    if ! command -v docker >/dev/null 2>&1; then
        echo "❌  docker 沒安裝。請啟動 Docker Desktop 或改用 foreground/launchd 模式。" >&2
        exit 1
    fi
    cd "$MAT_DIR" && docker compose "$@"
}

# Marker file (under data/, which is git-ignored and survives between runs)
# whose mtime records the last successful image build. `_needs_rebuild`
# compares source mtimes against it so `mat restart` can auto-promote to
# `up -d --build` whenever any baked-in source changed (see PR #78).
MAT_BUILT_AT="$MAT_DIR/data/.mat-built-at"

# Files & directories that get COPYed into the image at build time. If any
# of these is newer than $MAT_BUILT_AT, the running container has stale
# code and a plain `docker compose restart` would silently reuse the old
# image. Mirrors the COPY directives written by src/setup/deploy.py.
_MAT_REBUILD_PATHS=(
    "$MAT_DIR/src"
    "$MAT_DIR/main.py"
    "$MAT_DIR/requirements.txt"
    "$MAT_DIR/requirements.extra.txt"
    "$MAT_DIR/requirements.npm.txt"
    "$MAT_DIR/Dockerfile"
    "$MAT_DIR/docker-compose.yml"
)

# Returns 0 (true) when at least one source path is newer than the marker,
# or when the marker is missing (first run after this PR — treat as dirty
# so the next restart picks up the latest image regardless).
_needs_rebuild() {
    if [ ! -f "$MAT_BUILT_AT" ]; then
        return 0
    fi
    local p
    for p in "${_MAT_REBUILD_PATHS[@]}"; do
        # Skip paths that don't exist (e.g. requirements.extra.txt is
        # optional). `find` would error on a missing path otherwise.
        [ -e "$p" ] || continue
        # -newer compares mtime; -print -quit short-circuits on first hit
        # so we don't walk the whole tree once we know rebuild is needed.
        if [ -n "$(find "$p" -newer "$MAT_BUILT_AT" -print -quit 2>/dev/null)" ]; then
            return 0
        fi
    done
    return 1
}

# Touch the marker after a successful build. Creates data/ if missing
# (some fresh checkouts don't have it yet).
_touch_built_marker() {
    mkdir -p "$MAT_DIR/data"
    : > "$MAT_BUILT_AT" 2>/dev/null || touch "$MAT_BUILT_AT"
}

CMD="${1:-help}"

case "$CMD" in
    start)
        case "$(_backend)" in
            docker) exec bash -c "cd '$MAT_DIR' && docker compose up -d" ;;
            *)      _check_venv; exec "$AGENT" start ;;
        esac
        ;;
    stop)
        case "$(_backend)" in
            docker) _dc down ;;
            *)      exec "$AGENT" stop ;;
        esac
        ;;
    restart)
        case "$(_backend)" in
            docker)
                # Auto-rebuild when source changed. Plain `docker compose
                # restart` reuses the existing image — fine when only env
                # / config changed, but silently runs stale code after a
                # `git pull`. Compare mtimes against the build marker:
                #   - any source newer than marker → up -d --build + retouch
                #   - else                          → fast `restart`
                if _needs_rebuild; then
                    echo "🔄  偵測到 source 變更，重 build container..."
                    _dc up -d --build
                    _touch_built_marker
                else
                    _dc restart
                fi
                ;;
            *)      _check_venv; exec "$AGENT" restart ;;
        esac
        ;;
    status)
        case "$(_backend)" in
            docker) _dc ps ;;
            *)      exec "$AGENT" status ;;
        esac
        ;;
    logs)
        shift
        SUB="${1:-tail}"
        case "$(_backend)" in
            docker)
                case "$SUB" in
                    tail|"")          _dc logs -f gateway ;;
                    [0-9]*)           _dc logs --tail "$SUB" gateway ;;
                    grep)
                        [ -n "${2:-}" ] || { echo "用法: mat logs grep <pattern>"; exit 1; }
                        _dc logs gateway 2>&1 | grep -i "$2"
                        ;;
                    error|errors)
                        _dc logs gateway 2>&1 | grep -iE 'error|exception|traceback|critical'
                        ;;
                    today)
                        _dc logs gateway --since "$(date +%Y-%m-%d)T00:00:00"
                        ;;
                    *)
                        echo "用法: mat logs [tail|<N>|grep <pat>|error|today]"; exit 1
                        ;;
                esac
                ;;
            *)  exec "$AGENT" logs "$@" ;;
        esac
        ;;
    debug)
        # Toggle DEBUG_LOG in secrets/.env, then restart to pick it up.
        SUB="${2:-}"
        case "$SUB" in
            on|off)
                ENV_FILE="$MAT_DIR/secrets/.env"
                mkdir -p "$MAT_DIR/secrets"
                touch "$ENV_FILE"
                if grep -q '^DEBUG_LOG=' "$ENV_FILE"; then
                    # POSIX-portable in-place sed (macOS BSD vs GNU).
                    _tmp="$(mktemp)"
                    sed "s/^DEBUG_LOG=.*/DEBUG_LOG=$([ "$SUB" = on ] && echo true || echo false)/" "$ENV_FILE" > "$_tmp"
                    mv "$_tmp" "$ENV_FILE"
                else
                    echo "DEBUG_LOG=$([ "$SUB" = on ] && echo true || echo false)" >> "$ENV_FILE"
                fi
                chmod 600 "$ENV_FILE"
                echo "✅  DEBUG_LOG = $([ "$SUB" = on ] && echo true || echo false)"
                # Restart so the bot picks up the new env var.
                "$0" restart
                ;;
            *)
                echo "用法: mat debug on|off"; exit 1
                ;;
        esac
        ;;
    auth)
        # Container-internal device-flow OAuth for selected CLIs.
        # Each login command needs an interactive TTY (-it) — the CLI prints
        # a URL + device code, user authorizes in browser/mobile, pastes the
        # code back. Token persists in /root/.<cli>/ inside the named volume,
        # so it survives container restarts and image rebuilds.
        if [ "$(_backend)" != "docker" ]; then
            echo "ℹ️   非 docker 模式下，CLIs 直接使用 host 的 OAuth credential。"
            echo "    - claude   → 跑 'claude /login' 或先在 host 用 Claude Code 登入"
            echo "    - codex    → 跑 'codex login --device-auth'"
            echo "    - gemini   → 跑 'gemini auth login'（或設 GEMINI_API_KEY）"
            exit 0
        fi
        SUB="${2:-menu}"
        cd "$MAT_DIR"
        _do_auth() {
            local cli="$1" cmd="$2"
            echo "🔐  Authenticating $cli inside container..."
            echo "    Cmd: $cmd"
            echo "    （依提示在瀏覽器完成 OAuth；token 寫入 /root/.$cli/，會持久化）"
            echo
            # shellcheck disable=SC2086
            docker compose exec -it gateway $cmd
        }
        # Per-CLI login command (verified against actual CLI inside container):
        #   - claude: setup-token (subcommand exists in `claude --help`)
        #   - codex:  login --device-auth (CLI hint says "headless? use this")
        #   - gemini: NO `auth`/`login` subcommand — login is bootstrapped on
        #     first interactive run. We exec plain `gemini` in TTY mode and
        #     instruct user to complete OAuth then Ctrl-D / /quit out.
        _do_gemini_auth() {
            echo "🔐  Authenticating gemini inside container..."
            echo "    gemini-cli has no standalone login subcommand — we'll"
            echo "    open it interactively. On first run it asks you to"
            echo "    pick an auth method and complete Google OAuth. After"
            echo "    auth succeeds, type Ctrl-D or '/quit' to exit."
            echo "    （或: 設定 GEMINI_API_KEY 環境變數略過 OAuth — 在 secrets/.env 加 GEMINI_API_KEY=...）"
            echo
            docker compose exec -it gateway gemini
        }
        case "$SUB" in
            claude) _do_auth claude "claude setup-token" ;;
            codex)  _do_auth codex  "codex login --device-auth" ;;
            gemini) _do_gemini_auth ;;
            all)
                _do_auth claude "claude setup-token"
                _do_auth codex  "codex login --device-auth"
                _do_gemini_auth
                ;;
            menu|"")
                echo "選擇要認證的 CLI："
                echo "  1) claude  (claude setup-token)"
                echo "  2) codex   (codex login --device-auth)"
                echo "  3) gemini  (互動式啟動 gemini, OAuth 完成後 /quit)"
                echo "  4) all     (依序跑全部)"
                printf "Choice [1]: "
                read -r ans
                case "${ans:-1}" in
                    1) _do_auth claude "claude setup-token" ;;
                    2) _do_auth codex  "codex login --device-auth" ;;
                    3) _do_gemini_auth ;;
                    4) "$0" auth all ;;
                    *) echo "無效選項"; exit 1 ;;
                esac
                ;;
            status)
                # Quick check: does each CLI have credential file in volume?
                echo "📋  Auth status (/root inside container):"
                docker compose exec -T gateway sh -c '
                    for d in .claude .codex .gemini; do
                        if [ -d "/root/$d" ] && [ -n "$(ls -A /root/$d 2>/dev/null)" ]; then
                            echo "  ✓ $d ($(ls /root/$d | wc -l | tr -d " ") files)"
                        else
                            echo "  ✗ $d (empty / not authenticated)"
                        fi
                    done
                ' 2>&1
                ;;
            *)  echo "用法: mat auth [claude|codex|gemini|all|status|menu]"; exit 1 ;;
        esac
        ;;
    service-install)
        # Install service unit (launchd plist on macOS, systemd unit on Linux).
        # Docker mode has no equivalent — the container itself IS the daemon
        # and is managed by Docker.
        case "$(_backend)" in
            docker)
                echo "⚠️   Docker 模式下沒有 service unit；container 本身就是 daemon。"
                echo "    若要切到 launchd/systemd，請改 deploy_mode 並重跑 wizard。"
                ;;
            *)  exec "$AGENT" install ;;
        esac
        ;;
    service-uninstall)
        case "$(_backend)" in
            docker)
                echo "⚠️   Docker 模式下沒有 service unit。要停 container：mat stop"
                ;;
            *)  exec "$AGENT" uninstall ;;
        esac
        ;;
    run)
        # Foreground bot via host venv — bypasses whichever backend is
        # configured. Useful for local debugging regardless of deploy mode.
        _check_venv
        echo "▶  Foreground mode (Ctrl-C 停止)"
        cd "$MAT_DIR"
        exec "$PYTHON" main.py
        ;;
    setup)
        cd "$MAT_DIR"
        if [ ! -x "$PYTHON" ]; then
            echo "🐍  建立 venv..."
            python3 -m venv venv
            source venv/bin/activate
            echo "📦  安裝套件..."
            if [ "$(uname -s)" = "Darwin" ]; then
                pip install --quiet -r requirements.in
            else
                pip install --quiet -r requirements.txt
            fi
        fi
        # Force /dev/tty for interactive prompts so questionary's arrow-key
        # UI works even under `mat setup` invoked from non-tty pipelines.
        exec "$PYTHON" setup.py "${@:2}" </dev/tty >/dev/tty 2>&1
        ;;
    update)
        echo "⬇  git pull..."
        git -C "$MAT_DIR" pull --ff-only
        echo "✅  已更新"
        case "$(_backend)" in
            docker)
                echo "🔄  重 build container..."
                _dc up -d --build
                # Stamp the marker so the next `mat restart` skips a
                # redundant rebuild. Same hook is used by `mat restart`
                # itself when it auto-promotes to `up -d --build`.
                _touch_built_marker
                ;;
            *)
                if "$AGENT" status 2>/dev/null | grep -q running; then
                    "$AGENT" restart
                fi
                ;;
        esac
        ;;
    config)
        exec "$AGENT" config
        ;;
    install-cmd)
        # Symlink target must be the resolved real file, not the symlink itself.
        TARGET="$_SELF"
        # /usr/local/bin may not exist on minimal Linux (e.g. some Debian
        # containers) — create it so `ln -s` does not fail with ENOENT.
        if [ ! -d /usr/local/bin ]; then
            sudo mkdir -p /usr/local/bin
        fi
        sudo ln -sf "$TARGET" /usr/local/bin/mat
        echo "✅  已安裝：/usr/local/bin/mat → $TARGET"
        ;;
    mode)
        # Diagnostic: show current deploy mode + backend dispatch decision.
        echo "deploy_mode (state): $(_deploy_mode)"
        echo "backend (dispatch): $(_backend)"
        ;;
    help|--help|-h|*)
        BACKEND="$(_backend 2>/dev/null || echo unknown)"
        # Use ${BACKEND} braces — macOS bash 3.x with set -u treats the
        # following fullwidth `）` (UTF-8 3-byte) as part of the variable name
        # and reports "unbound variable" without the braces.
        echo "用法：mat <指令>      （目前部署模式：${BACKEND}）"
        echo ""
        echo "  生命週期"
        echo "    start                 啟動 bot"
        echo "    stop                  停止 bot"
        echo "    restart               重啟 bot（docker 模式：source 變更時自動 rebuild）"
        echo "    status                查看執行狀態"
        echo "    run                   前景執行（除錯用，繞過 backend）"
        echo ""
        echo "  日誌"
        echo "    logs                  即時 tail（Ctrl-C 離開）"
        echo "    logs <N>              最後 N 行"
        echo "    logs grep <pattern>   過濾關鍵字"
        echo "    logs error            只看錯誤訊息"
        echo "    logs today            只看今天的訊息"
        echo "    debug on | off        切換 DEBUG_LOG 並重啟"
        echo ""
        echo "  設定 / 維護"
        echo "    setup                 首次設定或重新配置 wizard"
        echo "    config                修改 Telegram / Discord token、白名單"
        echo "    update                git pull + 重啟 / 重 build"
        echo "    mode                  顯示目前 deploy mode（除錯用）"
        echo ""
        echo "  CLI agent OAuth（docker 模式必跑一次）"
        echo "    auth                  互動選單選 claude / codex / gemini"
        echo "    auth claude           只認證 claude（claude setup-token）"
        echo "    auth codex            只認證 codex （codex login --device-auth）"
        echo "    auth gemini           只認證 gemini（互動式 gemini，OAuth 後 /quit）"
        echo "    auth all              依序認證全部"
        echo "    auth status           查看哪些 CLI 已認證"
        echo ""
        echo "  service unit（launchd / systemd 模式）"
        echo "    service-install       建立並載入 service"
        echo "    service-uninstall     卸載 service"
        echo ""
        echo "  全域指令"
        echo "    install-cmd           安裝 mat 到 /usr/local/bin（一次性）"
        echo ""
        echo "  指令會依 deploy mode 自動 dispatch："
        echo "    docker → docker compose ..."
        echo "    launchd / systemd / foreground → ./agent ..."
        ;;
esac
