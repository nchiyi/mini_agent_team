# telegram-to-control

TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789
DEFAULT_CWD=/home/kiwi

# Ollama (OpenAI Compatible) API Authentication
# Option 1: Local / Network IP Address (default: localhost port 11434)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Option 2: Cloud API Key (for api.ollama.com)
OLLAMA_CLOUD_API_KEY=your_cloud_api_key_here

# Model (optional, default: llama3.1)
# DEFAULT_MODEL=llama3.1
