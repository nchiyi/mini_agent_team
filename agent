#!/bin/bash
# teltobot / agent management script

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

SERVICE_NAME="telegram-agent"

case "$1" in
    start)
        echo -e "${GREEN}🚀 Starting $SERVICE_NAME...${NC}"
        sudo systemctl start $SERVICE_NAME
        ;;
    stop)
        echo -e "${YELLOW}🛑 Stopping $SERVICE_NAME...${NC}"
        sudo systemctl stop $SERVICE_NAME
        ;;
    restart)
        echo -e "${GREEN}🔄 Restarting $SERVICE_NAME...${NC}"
        sudo systemctl restart $SERVICE_NAME
        ;;
    status)
        echo -e "${YELLOW}📊 Status of $SERVICE_NAME:${NC}"
        sudo systemctl status $SERVICE_NAME
        ;;
    logs)
        echo -e "${YELLOW}📜 Showing logs (Ctrl+C to stop):${NC}"
        sudo journalctl -u $SERVICE_NAME -f
        ;;
    debug)
        if [ "$2" == "on" ]; then
            echo -e "${GREEN}🐞 Turning Debug Logs ON...${NC}"
            sed -i 's/DEBUG_LOG=false/DEBUG_LOG=true/' .env
            sudo systemctl restart $SERVICE_NAME
        elif [ "$2" == "off" ]; then
            echo -e "${GREEN}🤐 Turning Debug Logs OFF...${NC}"
            sed -i 's/DEBUG_LOG=true/DEBUG_LOG=false/' .env
            sudo systemctl restart $SERVICE_NAME
        else
            echo -e "Usage: agent debug [on|off]"
        fi
        ;;
    config)
        echo -e "${GREEN}⚙️ Interactive Configuration${NC}"
        
        # Ensure .env exists
        if [ ! -f .env ]; then
            if [ -f .env.example ]; then
                cp .env.example .env
            else
                touch .env
            fi
        fi

        # Ask for Telegram Bot Token
        read -p "Enter Telegram Bot Token (leave blank to skip): " input_token
        if [ ! -z "$input_token" ]; then
            if grep -q "^TELEGRAM_BOT_TOKEN=" .env; then
                sed -i "s/^TELEGRAM_BOT_TOKEN=.*/TELEGRAM_BOT_TOKEN=$input_token/" .env
            else
                echo "TELEGRAM_BOT_TOKEN=$input_token" >> .env
            fi
            echo -e "${GREEN}✓ Token updated.${NC}"
        fi

        # Ask for Ollama Cloud API Key
        read -p "Enter Ollama Cloud API Key (leave blank to skip): " input_key
        if [ ! -z "$input_key" ]; then
            if grep -q "^OLLAMA_CLOUD_API_KEY=" .env; then
                sed -i "s/^OLLAMA_CLOUD_API_KEY=.*/OLLAMA_CLOUD_API_KEY=$input_key/" .env
            else
                echo "OLLAMA_CLOUD_API_KEY=$input_key" >> .env
            fi
            echo -e "${GREEN}✓ Cloud API Key updated.${NC}"
        fi

        # Ask for Default Model
        read -p "Enter Default Model [e.g. llama3.1, cloud:gpt-oss:120b] (leave blank to skip): " input_model
        if [ ! -z "$input_model" ]; then
            if grep -q "^DEFAULT_MODEL=" .env; then
                sed -i "s/^DEFAULT_MODEL=.*/DEFAULT_MODEL=$input_model/" .env
            else
                echo "DEFAULT_MODEL=$input_model" >> .env
            fi
            echo -e "${GREEN}✓ Default Model updated.${NC}"
        fi

        echo -e "${GREEN}✅ Configuration saved to .env! Restart the agent to apply changes: ./agent restart${NC}"
        ;;
    *)
        echo "Usage: agent {start|stop|restart|status|logs|debug|config}"
        exit 1
esac

exit 0
