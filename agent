#!/bin/bash
# gateway-agent management script

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

SERVICE_NAME="gateway-agent"
ENV_FILE="secrets/.env"

case "$1" in
    start)
        echo -e "${GREEN}🚀 Starting $SERVICE_NAME...${NC}"
        systemctl --user start $SERVICE_NAME
        ;;
    stop)
        echo -e "${YELLOW}🛑 Stopping $SERVICE_NAME...${NC}"
        systemctl --user stop $SERVICE_NAME
        ;;
    restart)
        echo -e "${GREEN}🔄 Restarting $SERVICE_NAME...${NC}"
        systemctl --user restart $SERVICE_NAME
        ;;
    status)
        echo -e "${YELLOW}📊 Status of $SERVICE_NAME:${NC}"
        systemctl --user status $SERVICE_NAME
        ;;
    logs)
        echo -e "${YELLOW}📜 Showing logs (Ctrl+C to stop):${NC}"
        journalctl --user -u $SERVICE_NAME -f
        ;;
    debug)
        if [ "$2" == "on" ]; then
            echo -e "${GREEN}🐞 Turning Debug Logs ON...${NC}"
            sed -i 's/DEBUG_LOG=false/DEBUG_LOG=true/' "$ENV_FILE"
            systemctl --user restart $SERVICE_NAME
        elif [ "$2" == "off" ]; then
            echo -e "${GREEN}🤐 Turning Debug Logs OFF...${NC}"
            sed -i 's/DEBUG_LOG=true/DEBUG_LOG=false/' "$ENV_FILE"
            systemctl --user restart $SERVICE_NAME
        else
            echo -e "Usage: agent debug [on|off]"
        fi
        ;;
    config)
        echo -e "${GREEN}⚙️  Configuration Editor${NC}"
        echo ""

        mkdir -p secrets
        if [ ! -f "$ENV_FILE" ]; then
            touch "$ENV_FILE"
            chmod 600 "$ENV_FILE"
        fi

        # ── helper: read current value ──────────────────────────
        _get() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'; }
        # ── helper: set or update a key ────────────────────────
        _set() {
            local key="$1" val="$2"
            if grep -qE "^${key}=" "$ENV_FILE" 2>/dev/null; then
                # macOS sed requires '' after -i
                sed -i'' -e "s|^${key}=.*|${key}=\"${val}\"|" "$ENV_FILE"
            else
                echo "${key}=\"${val}\"" >> "$ENV_FILE"
            fi
        }

        # ── show current values (masked) ────────────────────────
        _mask() { local v="$1"; [ -z "$v" ] && echo "(not set)" || echo "${v:0:6}…${v: -4}"; }
        echo "  Current values:"
        echo "    Telegram token : $(_mask "$(_get TELEGRAM_BOT_TOKEN)")"
        echo "    Discord token  : $(_mask "$(_get DISCORD_BOT_TOKEN)")"
        echo "    Allowed user IDs: $(_get ALLOWED_USER_IDS)"
        echo ""
        echo "  Press Enter to keep the current value."
        echo ""

        # ── Telegram ─────────────────────────────────────────────
        read -rp "  Telegram Bot Token: " _VAL
        [ -n "$_VAL" ] && _set TELEGRAM_BOT_TOKEN "$_VAL" && echo -e "  ${GREEN}✓ Updated${NC}"

        # ── Discord ──────────────────────────────────────────────
        read -rp "  Discord Bot Token : " _VAL
        [ -n "$_VAL" ] && _set DISCORD_BOT_TOKEN "$_VAL" && echo -e "  ${GREEN}✓ Updated${NC}"

        # ── Allowed user IDs ─────────────────────────────────────
        read -rp "  Allowed User IDs (comma-separated): " _VAL
        [ -n "$_VAL" ] && _set ALLOWED_USER_IDS "$_VAL" && echo -e "  ${GREEN}✓ Updated${NC}"

        echo ""

        # ── auto restart if service is running ──────────────────
        if systemctl --user is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
            echo -e "  ${YELLOW}Restarting $SERVICE_NAME to apply changes...${NC}"
            systemctl --user restart "$SERVICE_NAME"
            echo -e "  ${GREEN}✓ Restarted${NC}"
        else
            echo -e "  ${YELLOW}ℹ Bot is not running — changes will apply on next start.${NC}"
        fi
        echo ""
        echo -e "  ${GREEN}✅ Config saved to $ENV_FILE${NC}"
        ;;
    *)
        echo "Usage: agent {start|stop|restart|status|logs|debug [on|off]|config}"
        echo ""
        echo "  start           Start the bot service"
        echo "  stop            Stop the bot service"
        echo "  restart         Restart the bot service"
        echo "  status          Show service status"
        echo "  logs            Stream live logs (Ctrl-C to stop)"
        echo "  debug on|off    Toggle verbose debug logging"
        echo "  config          Update bot tokens and allowed user IDs"
        exit 1
esac

exit 0
