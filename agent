#!/usr/bin/env bash
# gateway-agent management script — supports macOS (launchd) and Linux (systemd)
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

SERVICE_NAME="gateway-agent"
PLIST_LABEL="com.kiwi.gateway-agent"
BOT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$BOT_DIR/secrets/.env"
LOG_FILE="$BOT_DIR/data/bot.log"
PLIST_FILE="$HOME/Library/LaunchAgents/$PLIST_LABEL.plist"

_os() { [[ "$(uname -s)" == "Darwin" ]] && echo macos || echo linux; }

# ── macOS launchd helpers ─────────────────────────────────────────────────

_plist_write() {
    mkdir -p "$HOME/Library/LaunchAgents"
    local FULL_PATH="$PATH:/usr/local/bin:/opt/homebrew/bin:$HOME/.local/bin:$HOME/.npm-global/bin"
    cat > "$PLIST_FILE" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>$PLIST_LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>$BOT_DIR/venv/bin/python3</string>
        <string>$BOT_DIR/main.py</string>
    </array>
    <key>WorkingDirectory</key><string>$BOT_DIR</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key><string>$FULL_PATH</string>
    </dict>
    <key>StandardOutPath</key><string>$LOG_FILE</string>
    <key>StandardErrorPath</key><string>$LOG_FILE</string>
    <key>KeepAlive</key><true/>
    <key>RunAtLoad</key><false/>
</dict>
</plist>
PLIST
}

_plist_loaded() { launchctl list "$PLIST_LABEL" &>/dev/null; }

_mac_start() {
    [ -f "$PLIST_FILE" ] || _plist_write
    if _plist_loaded; then
        launchctl stop "$PLIST_LABEL" 2>/dev/null || true
        sleep 1
        launchctl start "$PLIST_LABEL"
    else
        launchctl load "$PLIST_FILE"
        launchctl start "$PLIST_LABEL"
    fi
}

_mac_stop() {
    _plist_loaded && launchctl stop "$PLIST_LABEL" 2>/dev/null || true
}

_mac_status() {
    if _plist_loaded; then
        local pid
        pid=$(launchctl list | awk -v l="$PLIST_LABEL" '$3==l{print $1}')
        if [[ -n "$pid" && "$pid" != "-" ]]; then
            echo -e "${GREEN}● $SERVICE_NAME — running (PID $pid)${NC}"
        else
            echo -e "${YELLOW}○ $SERVICE_NAME — loaded but not running${NC}"
        fi
    else
        echo -e "${RED}○ $SERVICE_NAME — not installed${NC}"
        echo "  Run './agent install' to set up the launchd service."
    fi
}

# ── service commands ──────────────────────────────────────────────────────

case "${1:-}" in
    start)
        echo -e "${GREEN}🚀 Starting $SERVICE_NAME...${NC}"
        if [[ "$(_os)" == "macos" ]]; then
            _mac_start
            sleep 2
            _mac_status
        else
            systemctl --user start "$SERVICE_NAME"
        fi
        ;;

    stop)
        echo -e "${YELLOW}🛑 Stopping $SERVICE_NAME...${NC}"
        if [[ "$(_os)" == "macos" ]]; then
            _mac_stop
            echo -e "${YELLOW}Stopped.${NC}"
        else
            systemctl --user stop "$SERVICE_NAME"
        fi
        ;;

    restart)
        echo -e "${GREEN}🔄 Restarting $SERVICE_NAME...${NC}"
        if [[ "$(_os)" == "macos" ]]; then
            _mac_stop; sleep 1; _mac_start
            sleep 2; _mac_status
        else
            systemctl --user restart "$SERVICE_NAME"
        fi
        ;;

    status)
        if [[ "$(_os)" == "macos" ]]; then
            _mac_status
        else
            systemctl --user status "$SERVICE_NAME"
        fi
        ;;

    logs)
        echo -e "${YELLOW}📜 Live logs — Ctrl-C to stop${NC}"
        if [[ "$(_os)" == "macos" ]]; then
            tail -f "$LOG_FILE" 2>/dev/null || echo "No log at $LOG_FILE yet."
        else
            journalctl --user -u "$SERVICE_NAME" -f
        fi
        ;;

    install)
        if [[ "$(_os)" == "macos" ]]; then
            echo -e "${GREEN}📦 Installing launchd service...${NC}"
            _plist_write
            if ! _plist_loaded; then
                launchctl load "$PLIST_FILE"
            fi
            echo -e "  ${GREEN}✓ Installed: $PLIST_FILE${NC}"
            echo "  Run './agent start' to start."
        else
            echo "Linux: systemd unit is managed by the wizard (deploy mode = systemd)."
        fi
        ;;

    uninstall)
        if [[ "$(_os)" == "macos" ]]; then
            echo -e "${YELLOW}🗑  Uninstalling launchd service...${NC}"
            _mac_stop 2>/dev/null || true
            _plist_loaded && launchctl unload "$PLIST_FILE" 2>/dev/null || true
            rm -f "$PLIST_FILE"
            echo -e "${GREEN}✓ Removed.${NC}"
        else
            echo "Linux: use 'systemctl --user disable --now gateway-agent'."
        fi
        ;;

    debug)
        case "${2:-}" in
            on)
                echo -e "${GREEN}🐞 Debug logs ON${NC}"
                sed -i'' -e 's/DEBUG_LOG=.*/DEBUG_LOG=true/' "$ENV_FILE" 2>/dev/null || \
                    echo 'DEBUG_LOG=true' >> "$ENV_FILE"
                ;;
            off)
                echo -e "${GREEN}🤐 Debug logs OFF${NC}"
                sed -i'' -e 's/DEBUG_LOG=.*/DEBUG_LOG=false/' "$ENV_FILE" 2>/dev/null || \
                    echo 'DEBUG_LOG=false' >> "$ENV_FILE"
                ;;
            *) echo "Usage: ./agent debug [on|off]"; exit 1 ;;
        esac
        "$0" restart
        ;;

    config)
        echo -e "${GREEN}⚙️  Configuration Editor${NC}\n"
        mkdir -p secrets
        [ -f "$ENV_FILE" ] || { touch "$ENV_FILE"; chmod 600 "$ENV_FILE"; }

        _get() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'; }
        _set() {
            local key="$1" val="$2"
            if grep -qE "^${key}=" "$ENV_FILE" 2>/dev/null; then
                sed -i'' -e "s|^${key}=.*|${key}=\"${val}\"|" "$ENV_FILE"
            else
                echo "${key}=\"${val}\"" >> "$ENV_FILE"
            fi
        }
        _mask() { local v="$1"; [ -z "$v" ] && echo "(not set)" || echo "${v:0:6}…${v: -4}"; }

        echo "  Current values:"
        echo "    Telegram token   : $(_mask "$(_get TELEGRAM_BOT_TOKEN)")"
        echo "    Discord token    : $(_mask "$(_get DISCORD_BOT_TOKEN)")"
        echo "    Allowed user IDs : $(_get ALLOWED_USER_IDS)"
        echo ""
        echo "  Press Enter to keep current value."
        echo ""

        read -rp "  Telegram Bot Token : " _VAL </dev/tty
        [ -n "$_VAL" ] && _set TELEGRAM_BOT_TOKEN "$_VAL" && echo -e "  ${GREEN}✓ Updated${NC}"

        read -rp "  Discord Bot Token  : " _VAL </dev/tty
        [ -n "$_VAL" ] && _set DISCORD_BOT_TOKEN "$_VAL" && echo -e "  ${GREEN}✓ Updated${NC}"

        read -rp "  Allowed User IDs   : " _VAL </dev/tty
        [ -n "$_VAL" ] && _set ALLOWED_USER_IDS "$_VAL" && echo -e "  ${GREEN}✓ Updated${NC}"

        echo ""

        # auto-restart if service is running
        if [[ "$(_os)" == "macos" ]]; then
            if _plist_loaded && launchctl list | awk -v l="$PLIST_LABEL" '$3==l{print $1}' | grep -qE '^[0-9]+$'; then
                echo -e "  ${YELLOW}Restarting service to apply changes...${NC}"
                _mac_stop; sleep 1; _mac_start
                echo -e "  ${GREEN}✓ Restarted${NC}"
            else
                echo -e "  ${YELLOW}ℹ Bot not running — changes applied on next start.${NC}"
            fi
        else
            if systemctl --user is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
                echo -e "  ${YELLOW}Restarting service...${NC}"
                systemctl --user restart "$SERVICE_NAME"
                echo -e "  ${GREEN}✓ Restarted${NC}"
            else
                echo -e "  ${YELLOW}ℹ Bot not running — changes applied on next start.${NC}"
            fi
        fi
        echo ""
        echo -e "  ${GREEN}✅ Config saved to $ENV_FILE${NC}"
        ;;

    *)
        echo "Usage: ./agent <command>"
        echo ""
        echo "  start           Start the bot"
        echo "  stop            Stop the bot"
        echo "  restart         Restart the bot"
        echo "  status          Show running status"
        echo "  logs            Stream live logs (Ctrl-C to stop)"
        echo "  install         Install as background service (macOS: launchd)"
        echo "  uninstall       Remove background service"
        echo "  debug on|off    Toggle verbose debug logging"
        echo "  config          Update tokens and allowed user IDs"
        echo ""
        echo "  macOS:  uses launchd  (~/Library/LaunchAgents/)"
        echo "  Linux:  uses systemd  (systemctl --user)"
        exit 1
        ;;
esac

exit 0
