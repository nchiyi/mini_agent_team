# config/config.toml.example
# Copy to config/config.toml and edit

[gateway]
default_runner = "claude"
session_idle_minutes = 60
max_message_length_telegram = 4096
max_message_length_discord = 2000
stream_edit_interval_seconds = 1.5
# allow_all_users = false  # Set to true only for single-user local dev (no ALLOWED_USER_IDS needed)

[gateway.rate_limit]
enabled = true
per_user_per_minute = 10
burst = 3
max_concurrent_dispatches = 5
# Token budget limits (0 = no limit)
# daily_token_budget = 200000   # e.g. ~$1/day for Sonnet
# weekly_token_budget = 1000000
# warn_threshold = 0.8          # warn at 80% usage
# hard_stop_at_limit = false    # true=refuse dispatch; false=warn only

[runners.claude]
path = "claude"
args = []
# Uncomment the next line only if you accept the risk of bypassing tool confirmations:
# args = ["--dangerously-skip-permissions"]
timeout_seconds = 300
context_token_budget = 4000

[runners.codex]
path = "codex"
args = []
# Uncomment for fully-automated mode (bypasses confirmations — review risk before enabling):
# args = ["exec", "--full-auto", "--skip-git-repo-check"]
timeout_seconds = 300
context_token_budget = 4000

[runners.gemini]
path = "gemini"
args = []
# Uncomment for auto-approval mode (bypasses confirmations — review risk before enabling):
# args = ["--approval-mode", "yolo"]
timeout_seconds = 300
context_token_budget = 4000

[audit]
path = "data/audit"
max_entries = 1000

[memory]
db_path = "data/db/history.db"
hot_path = "data/memory/hot"
cold_permanent_path = "data/memory/cold/permanent"
cold_session_path = "data/memory/cold/session"
tier3_context_turns = 20
distill_trigger_turns = 20

[skills]
dir = "skills"
# [modules] is a deprecated alias for [skills] and still accepted

[voice]
stt_provider = "groq"          # "groq" | "faster-whisper"
tts_provider = "edge-tts"      # "edge-tts" | "gtts"
tts_voice = "zh-TW-HsiaoChenNeural"

# ── Per-channel auth overrides ──────────────────────────────────────────────
# Priority: per-channel explicit value > global ALLOWED_USER_IDS / allow_all_users > deny all
#
# [telegram] per-channel auth (optional — omit entirely to use global settings)
# [telegram]
# allowed_user_ids = [111222333]   # override: only these Telegram user IDs
# allow_all_users = false          # override: set true to open Telegram to everyone

# [discord] per-channel auth (optional — omit to use global settings)
[discord]
# allowed_channel_ids = []     # empty = all channels; fill to whitelist specific channels
# allowed_user_ids = [444555666]   # override: only these Discord user IDs
# allow_all_users = false          # override: set true to open Discord to everyone

# allow_user_messages — controls whether human (non-bot) messages are processed.
#   "off"      : ignore all human messages
#   "mentions" : only process messages that @mention this bot
#   "all"      : process every human message in allowed channels (default)
# Note: human-user authorization (ALLOWED_USER_IDS / allow_all_users) is still
#       enforced independently of this flag.
allow_user_messages = "all"    # "off" | "mentions" | "all"  — default: "all"

# allow_bot_messages — controls whether messages authored by other Discord bots are processed.
#   "off"      : ignore all bot messages (default; recommended for most deployments)
#   "mentions" : only process bot messages that @mention this bot
#   "all"      : process every bot message in allowed channels
# This flag is evaluated independently of allow_user_messages.
allow_bot_messages = "off"     # "off" | "mentions" | "all"  — default: "off"

# trusted_bot_ids — allowlist of Discord bot user IDs that may trigger this bot.
#   Only applies when allow_bot_messages != "off".
#   Empty list (default) means ALL bots are trusted (no ID filtering).
#   Fill with specific IDs to restrict to known relay bots only.
#   Interaction with allow_bot_messages:
#     - allow_bot_messages = "off"  → trusted_bot_ids is ignored entirely
#     - allow_bot_messages = "mentions"/"all" + trusted_bot_ids non-empty
#       → bot message must come from a listed ID AND satisfy the mentions rule
#     - allow_bot_messages = "mentions"/"all" + trusted_bot_ids empty
#       → any bot satisfying the mentions rule is accepted
# trusted_bot_ids = []         # e.g. [123456789012345678, 987654321098765432]

# ── 多 bot 模式（B-1） ──────────────────────────────────────────────────
# 在同一個 MAT process 啟用多個 Telegram bot，每個 bot 預先綁一個 CLI runner
# + roster role。 Memory 以 (user_id, channel, bot_id) 三元組隔離；不同 bot
# 的對話歷史絕不互通。
#
# 快速設定步驟：
#   1. 用 @BotFather 建立額外 bot，取得 token。
#   2. 在 secrets/.env 寫入 BOT_<ID>_TOKEN=... （ID 大寫，例 BOT_DEV_TOKEN）。
#   3. 取消下面範例的註解、改成你的 bot id / runner / role。
#   4. 重新啟動 MAT (`mat restart`)。
#
# 沒有 [bots.*] 區塊時，MAT 會走 legacy 單 bot 路徑（只認 TELEGRAM_BOT_TOKEN）—
# 既有安裝可以無痛升級。
#
# [bots.dev]
# channel        = "telegram"
# token_env      = "BOT_DEV_TOKEN"     # secrets/.env 內的 env var name
# default_runner = "claude"            # 此 bot 預設交給哪個 runner
# default_role   = "fullstack-dev"     # roster/<slug>.md 的 slug，可省略
# label          = "Dev Assistant"     # 純顯示用
#
# [bots.search]
# channel        = "telegram"
# token_env      = "BOT_SEARCH_TOKEN"
# default_runner = "gemini"
# default_role   = "researcher"
# label          = "Researcher"
#
# [bots.review]
# channel        = "telegram"
# token_env      = "BOT_REVIEW_TOKEN"
# default_runner = "codex"
# default_role   = "code-auditor"
# label          = "Code Reviewer"

# ── 群組協作（B-2） ────────────────────────────────────────────────────
# 把多個 bot 放進同一個 Telegram 群組，互相 @-mention 或對 @all 一起回應。
#
# Telegram 端必做：到 @BotFather → /setprivacy → 選此 bot → Disable，
# 才能讓 bot 看到群組裡所有訊息（不只 @-mention / 回覆 / slash command）。
# 如果只用 @username 定址、不用自然語言，可以保持 ON 也行。
#
# 群組記憶以 (user_id, channel, bot_id, chat_id) 四元組隔離 — 同一個 user 在
# DM 跟群組的對話歷史完全分桶，不會互相滲透。
#
# 防止 bot ↔ bot 無限對話：每個 (channel, chat_id) 連續 bot 訊息上限 10 次，
# 任何人類訊息會把計數歸零。
#
# 範例：dev_bot 進固定的工作群組、search_bot 開放給所有群組
#
# [bots.dev]
# channel              = "telegram"
# token_env            = "BOT_DEV_TOKEN"
# default_runner       = "claude"
# default_role         = "fullstack-dev"
# # 群組設定 ──────────────────────────────────
# allow_all_groups     = false                  # 預設 false：白名單模式
# allowed_chat_ids     = [-1001234567890]       # 只在這個群組答話
# allow_bot_messages   = "mentions"             # 別的 bot @ 我才回（off | mentions | all）
# respond_to_at_all   = false                  # 預設 false：忽略 @all/@大家/@everyone；改 true 才會回應
# trusted_bot_ids      = []                     # 空 = 允許所有 bot；填則白名單
#
# [bots.search]
# channel              = "telegram"
# token_env            = "BOT_SEARCH_TOKEN"
# default_runner       = "gemini"
# default_role         = "researcher"
# allow_all_groups     = true                   # 任何邀請我進的群組都能用
# allow_bot_messages   = "off"                  # 不回應其他 bot（避免 ping-pong）
