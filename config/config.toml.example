# config/config.toml.example
# Copy to config/config.toml and edit

[gateway]
default_runner = "claude"
session_idle_minutes = 60
max_message_length_telegram = 4096
max_message_length_discord = 2000
stream_edit_interval_seconds = 1.5

[gateway.rate_limit]
enabled = true
per_user_per_minute = 10
burst = 3
max_concurrent_dispatches = 5

[runners.claude]
path = "claude"
args = []
# Uncomment the next line only if you accept the risk of bypassing tool confirmations:
# args = ["--dangerously-skip-permissions"]
timeout_seconds = 300
context_token_budget = 4000

[runners.codex]
path = "codex"
args = ["exec", "--full-auto", "--skip-git-repo-check"]
timeout_seconds = 300
context_token_budget = 4000

[runners.gemini]
path = "gemini"
args = ["--approval-mode", "yolo"]
timeout_seconds = 300
context_token_budget = 4000

[audit]
path = "data/audit"
max_entries = 1000

[memory]
db_path = "data/db/history.db"
hot_path = "data/memory/hot"
cold_permanent_path = "data/memory/cold/permanent"
cold_session_path = "data/memory/cold/session"
tier3_context_turns = 20
distill_trigger_turns = 20

[modules]
dir = "modules"

[voice]
stt_provider = "groq"          # "groq" | "faster-whisper"
tts_provider = "edge-tts"      # "edge-tts" | "gtts"
tts_voice = "zh-TW-HsiaoChenNeural"

[discord]
# allowed_channel_ids = []     # empty = all channels; fill to whitelist specific channels
allow_bot_messages = "off"     # "off" | "mentions" | "all"
allow_user_messages = "all"    # "off" | "mentions" | "all"
# trusted_bot_ids = []         # bot Discord IDs allowed to trigger this bot (for multi-bot relay)
